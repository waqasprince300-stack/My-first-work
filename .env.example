NODE_ENV=development
# Local dev only. On Namecheap/cPanel live: omit PORT entirely — Passenger assigns it.
PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/waqas-emb-development

# If `mongodb+srv://` fails (local SRV/TXT DNS): set MONGODB_FALLBACK_URI to Atlas "standard"
# mongodb://… string, OR leave it unset — the server will retry via DNS-over-HTTPS (Cloudflare).
# To skip DoH: MONGODB_DISABLE_DOH=1
# MONGODB_FALLBACK_URI=mongodb://USER:PASS@host1:27017,host2:27017,host3:27017/dbname?tls=true&authSource=admin

# Avoid NODE_DNS_SERVERS unless required — often causes ETIMEOUT / ECONNREFUSED with Atlas.
# NODE_DNS_SERVERS=8.8.8.8,1.1.1.1

CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=10

# Platform super admin (use a DEDICATED account — not your day-to-day org admin).
# Signup/login block disposable and example domains; use a real address you control.
SUPER_ADMIN_NAME=Platform Admin
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# Legacy aliases for seed:admin if SUPER_ADMIN_* are unset
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Public URL of the React app (password reset links). Must match where users open the site.
FRONTEND_URL=http://localhost:3000

# Optional: real password-reset emails (production). Reset is sent TO the user's email.
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Optional one-time: existing account → platform super admin
# npm run promote:super-admin  (set PROMOTE_SUPER_ADMIN_EMAIL in .env first)
# PROMOTE_SUPER_ADMIN_EMAIL=
