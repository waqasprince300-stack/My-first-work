NODE_ENV=development
PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/waqas-emb-development
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_MINUTES=10
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password
FRONTEND_URL=http://localhost:3000
# Optional: configure these only when you want real reset emails.
# The reset email is sent TO the user-entered email address.
# These SMTP values are the app's sender mailbox credentials, not the logged-in user.
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
